{
  "sourceLanguage": "en",
  "strings": {
    "about": {
      "comment": "Button that opens the About window; also the window title.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "About"
          }
        }
      }
    },
    "aboutBuild": {
      "comment": "Build line in the About window. First %@ is the build number, second is the git commit hash.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Build %@ (%@)"
          }
        }
      }
    },
    "aboutCopied": {
      "comment": "Shown after the version link is clicked and the version summary is copied to the clipboard.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copied version to clipboard"
          }
        }
      }
    },
    "aboutCopyHelp": {
      "comment": "Tooltip on the version link explaining that clicking copies the version to the clipboard.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to copy version info"
          }
        }
      }
    },
    "aboutVersion": {
      "comment": "Version line in the About window. %@ is the version string.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Version %@"
          }
        }
      }
    },
    "allowEarlyReturnHelp": {
      "comment": "Help text for the Allow Early Return toggle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show the “I’m back” button before a break ends so you can return early."
          }
        }
      }
    },
    "allowEarlyReturnToggle": {
      "comment": "Toggle that enables the early “I’m back” button during a break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Early Return"
          }
        }
      }
    },
    "allowPostponeToggle": {
      "comment": "Preferences toggle to allow the user to postpone a break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Postpone"
          }
        }
      }
    },
    "autoStartOnLaunchHelp": {
      "comment": "Help text describing the auto-start-on-launch toggle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, a focus session starts automatically each time ShatterBreak launches."
          }
        }
      }
    },
    "autoStartOnLaunchToggle": {
      "comment": "Preferences toggle that starts a focus session automatically when the app launches.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start timer on launch"
          }
        }
      }
    },
    "close": {
      "comment": "Button that closes the Preferences window.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Close"
          }
        }
      }
    },
    "earlyReturnLeadExceedsRestWarning": {
      "comment": "Warning when the early-return lead is longer than the break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Early-return lead is longer than the break; “I’m back” shows for the whole break."
          }
        }
      }
    },
    "earlyReturnLeadHelp": {
      "comment": "Help text for the early-return lead slider.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How early the “I’m back” button appears before a break ends."
          }
        }
      }
    },
    "earlyReturnLeadLabel": {
      "comment": "Label for the slider setting how early the “I’m back” button appears.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show “I’m back” before end"
          }
        }
      }
    },
    "effectDimmed": {
      "comment": "Display name for the dimmed break effect (a plain dimmed overlay).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dimmed"
          }
        }
      }
    },
    "effectFogged": {
      "comment": "Display name for the fogged break effect (fogged glass over the desktop with cracks).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fogged"
          }
        }
      }
    },
    "effectShatter": {
      "comment": "Display name for the shatter break effect.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shatter"
          }
        }
      }
    },
    "effectTypePicker": {
      "comment": "Preferences picker label for choosing the break effect.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Effect Type"
          }
        }
      }
    },
    "generalSettings": {
      "comment": "Preferences section header for general settings.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "General Settings"
          }
        }
      }
    },
    "imBack": {
      "comment": "Overlay button the user taps to indicate they have returned from a break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm back"
          }
        }
      }
    },
    "later": {
      "comment": "Alert button that dismisses the permission prompt without taking action.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Later"
          }
        }
      }
    },
    "openSystemSettings": {
      "comment": "Alert button that opens System Settings to grant permission.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open System Settings"
          }
        }
      }
    },
    "openSystemSettingsToGrant": {
      "comment": "Link in the permission warning that opens System Settings to grant permission.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open System Settings to grant permission"
          }
        }
      }
    },
    "pause": {
      "comment": "Menu button that pauses the running work timer.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pause"
          }
        }
      }
    },
    "permissionAlertMessage": {
      "comment": "Body of the alert explaining how to grant Screen Recording permission.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shatter requires Screen Recording permission to capture your screen. Without it, breaks fall back to a frosted-glass effect. Enable it in System Settings → Privacy & Security → Screen & System Audio Recording."
          }
        }
      }
    },
    "permissionAlertTitle": {
      "comment": "Title of the alert prompting the user to grant Screen Recording permission.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen Recording Permission Required"
          }
        }
      }
    },
    "permissionWarningText": {
      "comment": "Inline warning shown when Screen Recording permission is missing.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shatter requires Screen Recording permission. Without it, breaks use a frosted-glass effect instead."
          }
        }
      }
    },
    "playSoundToggle": {
      "comment": "Preferences toggle that enables a sound when a break starts.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Play Sound"
          }
        }
      }
    },
    "postpone": {
      "comment": "Overlay button that postpones the current break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Postpone"
          }
        }
      }
    },
    "postponeDurationHelp": {
      "comment": "Help text for the Postpone duration slider.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How long a break is pushed back when you tap Postpone."
          }
        }
      }
    },
    "postponeDurationLabel": {
      "comment": "Label for the slider setting how long a postpone pushes the break back.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Postpone duration"
          }
        }
      }
    },
    "postponeWindowExceedsRestWarning": {
      "comment": "Warning when the Postpone window is longer than the break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Postpone window is longer than the break; Postpone stays for the whole break."
          }
        }
      }
    },
    "postponeWindowHelp": {
      "comment": "Help text for the Postpone window slider.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How long the Postpone button stays on screen after a break begins."
          }
        }
      }
    },
    "postponeWindowLabel": {
      "comment": "Label for the slider setting how long the Postpone button stays visible.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Postpone available for"
          }
        }
      }
    },
    "preferences": {
      "comment": "Title of the Preferences window and the menu button that opens it.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preferences"
          }
        }
      }
    },
    "quit": {
      "comment": "Menu button that quits the app.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit"
          }
        }
      }
    },
    "ready": {
      "comment": "Idle state shown in the menu when no timer is running.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ready"
          }
        }
      }
    },
    "restDuration": {
      "comment": "Label for the rest duration slider.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rest Duration"
          }
        }
      }
    },
    "resume": {
      "comment": "Menu button that resumes a paused timer.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resume"
          }
        }
      }
    },
    "showTimerInMenuBarHelp": {
      "comment": "Help text describing the show-timer-in-menu-bar toggle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, the remaining time will be shown next to the app icon in the menu bar."
          }
        }
      }
    },
    "showTimerInMenuBarToggle": {
      "comment": "Preferences toggle that shows the remaining time in the menu bar.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show timer in menu bar"
          }
        }
      }
    },
    "skipRest": {
      "comment": "Menu button that skips the current rest period.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip Rest"
          }
        }
      }
    },
    "softOverlayToggle": {
      "comment": "Preferences toggle that uses a soft overlay allowing menu bar access.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Soft Overlay (allows menu bar access)"
          }
        }
      }
    },
    "startFocus": {
      "comment": "Menu button that starts a focus session.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start Focus"
          }
        }
      }
    },
    "startWorkAfterBreakEnds": {
      "comment": "Preferences picker label for choosing when work resumes after a break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start work after break ends"
          }
        }
      }
    },
    "stop": {
      "comment": "Menu button that stops the running timer.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stop"
          }
        }
      }
    },
    "timeToRest": {
      "comment": "Headline shown on the break overlay.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Time to rest"
          }
        }
      }
    },
    "windowsOverlapWarning": {
      "comment": "Warning when the Postpone and “I’m back” windows overlap.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Postpone and “I’m back” windows overlap — both buttons can appear at once."
          }
        }
      }
    },
    "workDuration": {
      "comment": "Label for the work duration slider.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Work Duration"
          }
        }
      }
    },
    "workStartModeAutomatic": {
      "comment": "Display name for resuming work automatically after a break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic"
          }
        }
      }
    },
    "workStartModeHelp": {
      "comment": "Help text describing the start-work-after-break picker.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose whether the work timer should automatically start when your rest finishes or wait until you press a button."
          }
        }
      }
    },
    "workStartModeManual": {
      "comment": "Display name for resuming work manually after a break.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manual"
          }
        }
      }
    }
  },
  "version": "1.0"
}
